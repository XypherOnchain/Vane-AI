# App
NODE_ENV=development
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000

# Database
DATABASE_URL=postgresql://vane:vane@localhost:5432/vane
REDIS_URL=redis://localhost:6379

# Robinhood Chain
RPC_URL=https://rpc.mainnet.chain.robinhood.com
WSS_URL=wss://feed.mainnet.chain.robinhood.com
CHAIN_ID=4663

# Telegram — never commit real tokens
TELEGRAM_BOT_TOKEN=

# LLM (optional — agent falls back to deterministic summaries without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Scale / security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
API_KEY=

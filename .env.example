# --- Runtime -----------------------------------------------------------------
NODE_ENV=development

# Demo mode gates ALL simulated intelligence. Defaults to false.
# It can only be enabled deliberately in development, never in production.
VANE_DEMO_MODE=false

# --- Data stores (required in production) --------------------------------------
DATABASE_URL=postgresql://vane:vane@localhost:5432/vane
REDIS_URL=redis://localhost:6379

# --- Robinhood Chain RPC (canonical names; required in production) -------------
# Production must use dedicated providers. The rate-limited public RPC
# (https://rpc.mainnet.chain.robinhood.com) is refused as a production provider.
ROBINHOOD_RPC_PRIMARY=
ROBINHOOD_RPC_BACKUP=
ROBINHOOD_RPC_ARCHIVE=
ROBINHOOD_WS_PRIMARY=
ROBINHOOD_WS_BACKUP=

# Legacy per-network names (development fallback only)
ROBINHOOD_MAINNET_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_MAINNET_RPC_BACKUP_URL=
ROBINHOOD_MAINNET_WS_URL=
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
ROBINHOOD_TESTNET_RPC_BACKUP_URL=
ROBINHOOD_TESTNET_WS_URL=

# --- URLs & networking ---------------------------------------------------------
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Comma-separated list of allowed browser origins (required in production)
CORS_ORIGINS=

# --- Secrets (required in production, min 16 chars) ----------------------------
INTERNAL_API_SECRET=
AUTH_SECRET=

# --- Telegram -------------------------------------------------------------------
TELEGRAM_PAIRS_BOT_TOKEN=
TELEGRAM_PAIRS_WEBHOOK_SECRET=
TELEGRAM_INTELLIGENCE_BOT_TOKEN=
TELEGRAM_INTELLIGENCE_WEBHOOK_SECRET=

# --- AI --------------------------------------------------------------------------
AI_PROVIDER_API_KEY=
AI_MODEL=gpt-4o-mini

# --- Simulation (Phase 1 Repair) -------------------------------------------------
# Prefer Tenderly when set; otherwise Anvil fork via FORK_RPC_URL.
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=
TENDERLY_ACCESS_KEY=
FORK_RPC_URL=
ANVIL_BIN=anvil

# --- GitHub (Phase 1 Workspace / repo index) ------------------------------------
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Telegram Debug bot (Phase 1 remote) ----------------------------------------
TELEGRAM_DEBUG_BOT_TOKEN=

# --- Tuning ------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
INDEXER_WORKERS=2
INDEXER_POLL_MS=4000
ACTIVE_CHAIN=mainnet

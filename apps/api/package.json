{
  "name": "@vane/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/main.ts",
    "build": "tsc",
    "start": "node --env-file=../../.env dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "loadtest": "tsx --env-file=../../.env scripts/loadtest.ts"
  },
  "dependencies": {
    "@vane/chain": "workspace:*",
    "@vane/config": "workspace:*",
    "@vane/project-graph": "workspace:*",
    "@vane/shared-types": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "ioredis": "^5.6.0",
    "pg": "^8.14.1",
    "uuid": "^11.1.0",
    "viem": "^2.55.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}

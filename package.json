{
  "name": "vane-ai",
  "private": true,
  "version": "0.1.0",
  "description": "Vane AI — The intelligence layer for Robinhood Chain",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@vane/web --filter=@vane/api --filter=@vane/indexer --filter=@vane/worker",
    "dev:web": "turbo run dev --filter=@vane/web --filter=@vane/api",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @vane/database migrate",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
